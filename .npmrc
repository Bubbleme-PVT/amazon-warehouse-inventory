from pathlib import Path
import zipfile, shutil, json, subprocess, textwrap

src_zip = Path('/mnt/data/amazon-warehouse-inventory-react-node-tsv.zip')
work = Path('/mnt/data/cloudflare_fix_work')
if work.exists():
    shutil.rmtree(work)
work.mkdir(parents=True)

with zipfile.ZipFile(src_zip, 'r') as z:
    z.extractall(work)

dirs = [p for p in work.iterdir() if p.is_dir()]
project = dirs[0] if dirs else work

pkg_path = project / 'package.json'
pkg = json.loads(pkg_path.read_text())

pkg["name"] = "amazon-warehouse-inventory"
pkg["version"] = "1.0.0"
pkg["private"] = True
pkg["type"] = "module"
pkg["scripts"] = {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server.js",
    "serve": "npm run build && node server.js"
}
pkg["dependencies"] = {
    "@vitejs/plugin-react": "latest",
    "vite": "^7.2.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "express": "^4.22.1",
    "xlsx": "^0.18.5"
}
pkg["devDependencies"] = {}

pkg_path.write_text(json.dumps(pkg, indent=2) + "\n")

# Remove lockfile so Cloudflare uses npm install instead of npm clean-install/npm ci.
for name in ["package-lock.json", "npm-shrinkwrap.json"]:
    p = project / name
    if p.exists():
        p.unlink()

(project / ".npmrc").write_text(textwrap.dedent("""
fund=false
audit=false
progress=false
legacy-peer-deps=true
""").strip() + "\n")

(project / "wrangler.toml").write_text(textwrap.dedent("""
name = "amazon-warehouse-inventory"
pages_build_output_dir = "dist"
compatibility_date = "2026-04-24"
""").strip() + "\n")

(project / "README.md").write_text(textwrap.dedent("""
# Amazon Warehouse Inventory Planner

React + Node.js warehouse planner for Bubble Me Amazon inventory.

## Cloudflare Pages Settings

Use these exact settings:

```text
Root directory: /
Build command: npm run build
Build output directory: dist
Node version: 20
